{
    "name": "kalna-lab/scrive",
    "description": "Laravel package for integrating with the Scrive eID and document signing APIs",
    "keywords": [
        "laravel",
        "scrive",
        "mitid",
        "eid",
        "esignature",
        "document-signing"
    ],
    "homepage": "https://github.com/kalna-lab/scrive",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Claus Hjort Bube",
            "email": "claus@kalna.it",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "nesbot/carbon": "^2.62|^3.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/kalna-lab/scrive"
        }
    ],
    "autoload": {
        "psr-4": {
            "KalnaLab\\Scrive\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KalnaLab\\Scrive\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "format-check": "vendor/bin/pint --test"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KalnaLab\\Scrive\\ScriveServiceProvider"
            ],
            "aliases": {
                "Scrive": "KalnaLab\\Scrive\\Facades\\Scrive"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
